# Production Environment Configuration
# Copy this to .env.local on your EC2 instance

# Algolia Configuration
ALGOLIA_APP_ID=DCCC0T0ITC
ALGOLIA_API_KEY=870d45e2eaf4483e87c2204607df57c7
ALGOLIA_INDEX_NAME=prometheux-co

# AI Provider Configuration - SET THESE ON EC2
# Anthropic is tried first; Azure OpenAI is used as fallback.
