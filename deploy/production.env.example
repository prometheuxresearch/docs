# Azure OpenAI (fallback)
AZURE_OPENAI_ENDPOINT=https://davbe-mdg4jzfa-eastus2.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_KEY=your_azure_openai_key_here

# Production Settings
NODE_ENV=production 